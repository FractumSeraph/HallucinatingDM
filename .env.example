# --- Required ---------------------------------------------------------------
# Secret used to sign auth tokens and encrypt stored API keys.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# --- LLM provider -----------------------------------------------------------
# Any OpenAI-compatible /v1 endpoint works: Ollama, LM Studio, vLLM,
# OpenCode Go, OpenRouter, OpenAI, an Anthropic-compatible gateway, etc.
# These are defaults; they can be overridden at runtime in the /admin UI.
LLM_PROVIDER=openai_compat          # openai_compat | mock
LLM_BASE_URL=http://ollama:11434/v1 # http://localhost:11434/v1 outside compose
LLM_API_KEY=ollama                  # ignored by Ollama, required by cloud APIs
# Default targets a 12GB-VRAM GPU (e.g. RTX 3060) + ~32GB system RAM: a 24GB
# MoE download with only ~3B active params, so CPU-offloaded experts stay fast.
# Strong native tool calling and 256k-native context. Smaller fallback: qwen3:14b.
LLM_MODEL=qwen3.6:35b-a3b
# Hosted alternative (OpenCode Go, $10/mo — https://opencode.ai/go):
#   LLM_BASE_URL=https://opencode.ai/zen/go/v1
#   LLM_API_KEY=<your OpenCode Zen key>
#   LLM_MODEL=qwen3.6-plus
# native | prompted | auto — how tool calls are issued to the model.
# "auto" probes native tool support and falls back to prompted JSON.
LLM_TOOLCALL_MODE=auto

# Embeddings can point at a different server than chat.
EMBEDDING_BASE_URL=http://ollama:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text

# --- Server -----------------------------------------------------------------
DATA_DIR=/data                      # SQLite db + uploads live here
PORT=8080
# Set to the public origin if you serve over HTTPS behind a proxy, e.g.
# https://dnd.example.com — used for secure-cookie settings.
PUBLIC_ORIGIN=
